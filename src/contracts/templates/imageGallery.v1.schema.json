{
  "$id": "https://microsense.ai/schemas/ai2x/templates/imageGallery.v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["images"],
  "properties": {
    "title": { "type": "string" },
    "subtitle": { "type": "string" },
    "layout": { "type": "string", "enum": ["grid", "list"] },
    "autoplay": { "type": "boolean" },
    "intervalMs": { "type": "number" },
    "images": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["url"],
        "properties": {
          "url": { "type": "string", "minLength": 1 },
          "title": { "type": "string" },
          "caption": { "type": "string" },
          "source": { "type": "string" },
          "fit": { "type": "string", "enum": ["cover", "contain", "fill", "none", "scale-down"] },
          "bg": { "type": "string" }
        }
      }
    }
  }
}
