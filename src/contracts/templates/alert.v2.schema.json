{
  "$id": "https://microsense.ai/schemas/ai2x/templates/alert.v2.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "message"],
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "message": { "type": "string", "minLength": 1 },
    "level": { "type": "string", "enum": ["info", "warning", "success", "error"] }
  }
}
