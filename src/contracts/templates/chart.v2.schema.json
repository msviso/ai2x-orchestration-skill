{
  "$id": "https://microsense.ai/schemas/ai2x/templates/chart.v2.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["type", "x", "series"],
  "properties": {
    "title": { "type": "string" },
    "subtitle": { "type": "string" },
    "type": { "type": "string", "enum": ["line", "bar"] },
    "x": {
      "type": "object",
      "additionalProperties": false,
      "required": ["labels"],
      "properties": {
        "labels": { "type": "array", "items": { "type": "string" } }
      }
    },
    "series": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "data"],
        "properties": {
          "name": { "type": "string" },
          "data": { "type": "array", "items": { "type": "number" } }
        }
      }
    },
    "options": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "unit": { "type": "string" },
        "decimals": { "type": "number" },
        "yMin": { "type": "number" },
        "yMax": { "type": "number" },
        "legend": { "type": "boolean" },
        "grid": { "type": "boolean" },
        "smooth": { "type": "boolean" },
        "stacked": { "type": "boolean" }
      }
    }
  }
}
